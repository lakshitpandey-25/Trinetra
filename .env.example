# TRINETRA — Environment Variables Template
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ── Twilio (SMS / IVR Alerts) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+1xxxxxxxxxx

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=your_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Webhook URLs (JSON array) ─────────────────────────────────────────────────
ALERT_WEBHOOKS=["https://your-dashboard.gov.in/webhook"]

# ── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Google Earth Engine ───────────────────────────────────────────────────────
# Run: python -c "import ee; ee.Authenticate()" to set up credentials
EE_PROJECT=your-gee-project-id
